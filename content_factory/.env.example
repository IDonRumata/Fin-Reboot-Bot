# Gemini API (получить на https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Telegram ID Андрея (для получения превью на одобрение)
ANDREY_TELEGRAM_ID=your_telegram_id_here
# ID канала ГраФин (начинается с -100...)
GRAFIN_CHANNEL_ID=-1001234567890

# Google Sheets
# Путь к JSON-ключу сервисного аккаунта
GOOGLE_CREDENTIALS_PATH=credentials.json
# ID таблицы контент-плана (из URL: docs.google.com/spreadsheets/d/ID/edit)
CONTENT_SHEET_ID=your_sheet_id_here

# Настройки контента
# Имя дальнобойщика
AUTHOR_NAME=Андрей
# Дата старта челенджа с отжиманиями (YYYY-MM-DD)
PUSHUP_CHALLENGE_START=2025-10-25
# Начальное количество отжиманий
PUSHUP_CHALLENGE_START_COUNT=10
