# === Telegram ===
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=[your_telegram_id]

# === Database ===
DATABASE_URL=postgresql+asyncpg://finbot:finbot_pass@postgres:5432/finbot_db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === bePaid ===
BEPAID_SHOP_ID=your_shop_id
BEPAID_SECRET_KEY=your_secret_key
BEPAID_CHECKOUT_URL=https://checkout.bepaid.by/ctp/api/checkouts
BEPAID_PAYMENT_URL=your_payment_url
BEPAID_WEBHOOK_SECRET=

# === Webhook server ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8443

# === WebApps ===
WEBAPP_CALC_URL=https://t.me/your_bot/calc
WEBAPP_TRACKER_URL=https://t.me/your_bot/tracker

# === Misc ===
SUPPORT_USERNAME=@your_username
PARTICIPANTS_CHAT_URL=https://t.me/+your_chat_link
LOG_LEVEL=INFO
